      "defaultFilters": ["status IN ('POSTED', 'RETURN')"],
      "mandatorySecurityFilters": ["tenant_id", "company_id when session is company-scoped", "branch_id when session is branch-scoped"],
      "supportedReports": ["sales-overview", "sales-bills", "sales-bill-drilldown", "sales-item-drilldown", "sales-dimension-analysis", "growth-comparison", "customer-360", "item-360", "tax-summary"]
