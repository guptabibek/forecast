        { "name": "branch_id", "type": "uuid", "description": "Mapped branch/location identifier", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": true },
        { "name": "financial_year", "type": "text", "description": "Fiscal year from tenant default fiscal calendar when available", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "invoice_id", "type": "text", "description": "Stable Marg invoice key: company_id:voucher", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "invoice_no", "type": "text", "description": "Visible invoice number from VCN or voucher", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "invoice_date", "type": "date", "description": "Sales invoice date", "isMetricBase": false, "isDimension": false, "isFilter": true, "isSecurityFilter": false },
        { "name": "customer_code", "type": "text", "description": "Marg customer code", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "customer_name", "type": "text", "description": "Customer name from Marg party/customer mapping", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "salesman_code", "type": "text", "description": "Salesman/MR code used by production reports", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "product_code", "type": "text", "description": "Product code, falling back to Marg product code or PID", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "product_name", "type": "text", "description": "Product name, falling back to Marg product name", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "batch_no", "type": "text", "description": "Marg batch number on the line", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "quantity", "type": "double precision", "description": "Absolute sold/returned quantity", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "gross_amount", "type": "double precision", "description": "ABS(quantity) multiplied by rate", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "discount_amount", "type": "double precision", "description": "Gross amount less absolute line amount, floored at zero", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "taxable_amount", "type": "double precision", "description": "Line amount where tax rate is positive", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "non_taxable_amount", "type": "double precision", "description": "Line amount where tax rate is zero", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "tax_rate", "type": "double precision", "description": "Marg GST/VAT percentage", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false },
        { "name": "tax_amount", "type": "double precision", "description": "Absolute GST/VAT amount", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "net_amount", "type": "double precision", "description": "Line amount plus tax amount", "isMetricBase": true, "isDimension": false, "isFilter": false, "isSecurityFilter": false },
        { "name": "status", "type": "text", "description": "POSTED or RETURN according to Marg voucher type", "isMetricBase": false, "isDimension": true, "isFilter": true, "isSecurityFilter": false }
