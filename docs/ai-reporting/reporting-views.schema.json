      "domain": "sales",
      "grain": "item_level",
      "description": "Item-level Marg sales and sales-return reporting dataset",
      "columns": [
        { "name": "tenant_id", "type": "uuid", "description": "Tenant security scope", "isMetricBase": false, "isDimension": false, "isFilter": true, "isSecurityFilter": true },
