// Forecast Accuracy Metrics — Track MAPE/Bias/Signal per SKU over time
model ForecastAccuracyMetric {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  locationId      String?   @map("location_id") @db.Uuid
  periodDate      DateTime  @map("period_date") @db.Date
  forecastQty     Decimal   @map("forecast_qty") @db.Decimal(18, 4)
  actualQty       Decimal   @map("actual_qty") @db.Decimal(18, 4)
  mape            Decimal?  @db.Decimal(10, 4)
  bias            Decimal?  @db.Decimal(10, 4)
  trackingSignal  Decimal?  @map("tracking_signal") @db.Decimal(10, 4)
  mad             Decimal?  @db.Decimal(10, 4)
  forecastModel   String?   @map("forecast_model") @db.VarChar(100)
  forecastVersion String?   @map("forecast_version") @db.VarChar(50)
  granularity     String    @default("MONTHLY") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at")
  product         Product   @relation("ProductAccuracyMetrics", fields: [productId], references: [id])
  location        Location? @relation("LocationAccuracyMetrics", fields: [locationId], references: [id])

  @@unique([tenantId, productId, locationId, periodDate, granularity])
  @@index([tenantId, periodDate])
  @@index([tenantId, productId])
  @@map("forecast_accuracy_metrics")
}

