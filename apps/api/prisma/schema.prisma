// ============================================================================
// ENTERPRISE COSTING ENGINE — Cost Layers, Valuation, Revaluation
// ============================================================================

enum CostingMethod {
  STANDARD
  MOVING_AVERAGE
  FIFO
  LIFO
  ACTUAL_JOB_COSTING
}

enum CostLayerStatus {
  OPEN
  DEPLETED
  FROZEN
}

enum RevaluationStatus {
  DRAFT
  POSTED
  REVERSED
}

enum PeriodCloseStatus {
  OPEN
  CLOSING
  CLOSED
  REOPENED
}

/// Per-item costing method configuration — drives how cost flows through ledger
model ItemCostProfile {
  id                  String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  productId           String        @map("product_id") @db.Uuid
  locationId          String?       @map("location_id") @db.Uuid
  costingMethod       CostingMethod @default(STANDARD) @map("costing_method")
  standardCostVersion String?       @map("standard_cost_version") @db.VarChar(50)
  enableLandedCost    Boolean       @default(false) @map("enable_landed_cost")
  overheadRate        Decimal?      @map("overhead_rate") @db.Decimal(18, 4)
  laborRate           Decimal?      @map("labor_rate") @db.Decimal(18, 4)
  currency            String        @default("USD") @db.VarChar(3)
  isActive            Boolean       @default(true) @map("is_active")
  effectiveFrom       DateTime      @default(now()) @map("effective_from") @db.Date
  effectiveTo         DateTime?     @map("effective_to") @db.Date
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, productId, locationId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("item_cost_profiles")
}

/// Immutable cost layer — one per receipt for FIFO/LIFO; single live row per (product,location) for MOVING_AVERAGE
model CostLayer {
  id              String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  productId       String               @map("product_id") @db.Uuid
  locationId      String               @map("location_id") @db.Uuid
  batchId         String?              @map("batch_id") @db.Uuid
  costingMethod   CostingMethod        @map("costing_method")
  layerDate       DateTime             @default(now()) @map("layer_date")
  referenceType   String               @map("reference_type") @db.VarChar(50)
  referenceId     String               @map("reference_id") @db.Uuid
  referenceNumber String?              @map("reference_number") @db.VarChar(50)
  originalQty     Decimal              @map("original_qty") @db.Decimal(18, 4)
  remainingQty    Decimal              @map("remaining_qty") @db.Decimal(18, 4)
  unitCost        Decimal              @map("unit_cost") @db.Decimal(18, 4)
  totalCost       Decimal              @map("total_cost") @db.Decimal(18, 4)
  landedCost      Decimal              @default(0) @map("landed_cost") @db.Decimal(18, 4)
  currency        String               @default("USD") @db.VarChar(3)
  exchangeRate    Decimal              @default(1) @map("exchange_rate") @db.Decimal(18, 8)
  baseCurrCost    Decimal              @default(0) @map("base_curr_cost") @db.Decimal(18, 4)
  fiscalPeriodId  String?              @map("fiscal_period_id") @db.Uuid
  status          CostLayerStatus      @default(OPEN)
  version         Int                  @default(1)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  depletions      CostLayerDepletion[] @relation("LayerDepletions")

  @@index([tenantId, productId, locationId, status])
  @@index([tenantId, productId, locationId, status, layerDate])
  @@index([tenantId, productId, locationId, layerDate])
  @@index([tenantId, fiscalPeriodId])
  @@index([referenceType, referenceId])
  @@map("cost_layers")
}

/// Tracks each consumption from a cost layer (FIFO/LIFO depletion audit trail)
model CostLayerDepletion {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  costLayerId     String    @map("cost_layer_id") @db.Uuid
  depletedQty     Decimal   @map("depleted_qty") @db.Decimal(18, 4)
  unitCost        Decimal   @map("unit_cost") @db.Decimal(18, 4)
  totalCost       Decimal   @map("total_cost") @db.Decimal(18, 4)
  referenceType   String    @map("reference_type") @db.VarChar(50)
  referenceId     String    @map("reference_id") @db.Uuid
  referenceNumber String?   @map("reference_number") @db.VarChar(50)
  depletedAt      DateTime  @default(now()) @map("depleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  costLayer       CostLayer @relation("LayerDepletions", fields: [costLayerId], references: [id])

  @@index([tenantId, costLayerId])
  @@index([referenceType, referenceId])
  @@map("cost_layer_depletions")
}

/// Moving average cost tracker per (product, location, site)
model ItemCost {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  locationId        String    @map("location_id") @db.Uuid
