  fiscalPeriodId    String?           @map("fiscal_period_id") @db.Uuid
  oldUnitCost       Decimal           @map("old_unit_cost") @db.Decimal(18, 4)
  newUnitCost       Decimal           @map("new_unit_cost") @db.Decimal(18, 4)
  affectedQty       Decimal           @map("affected_qty") @db.Decimal(18, 4)
  revaluationAmount Decimal           @map("revaluation_amount") @db.Decimal(18, 4)
