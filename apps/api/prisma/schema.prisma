model InventoryTransaction {
  id              String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  transactionType InventoryTransactionType @map("transaction_type")
  productId       String                   @map("product_id") @db.Uuid
  locationId      String                   @map("location_id") @db.Uuid
  quantity        Decimal                  @db.Decimal(18, 4)
  uom             String                   @db.VarChar(20)
  transactionDate DateTime                 @map("transaction_date")
  referenceType   String?                  @map("reference_type") @db.VarChar(50)
  referenceId     String?                  @map("reference_id") @db.Uuid
  referenceNumber String?                  @map("reference_number") @db.VarChar(50)
  idempotencyKey  String?                  @map("idempotency_key") @db.VarChar(100)
  lotNumber       String?                  @map("lot_number") @db.VarChar(50)
  batchId         String?                  @map("batch_id") @db.Uuid
  toLocationId    String?                  @map("to_location_id") @db.Uuid
  unitCost        Decimal?                 @map("unit_cost") @db.Decimal(18, 4)
  totalCost       Decimal?                 @map("total_cost") @db.Decimal(18, 4)
  reason          String?                  @db.VarChar(255)
  notes           String?
  createdById     String                   @map("created_by_id") @db.Uuid
  createdAt       DateTime                 @default(now()) @map("created_at")
  product         Product                  @relation("ProductTransactions", fields: [productId], references: [id])
  location        Location                 @relation("LocationTransactions", fields: [locationId], references: [id])
  toLocation      Location?                @relation("TransferToLocation", fields: [toLocationId], references: [id])
  batch           Batch?                   @relation("BatchTransactions", fields: [batchId], references: [id])
  createdBy       User                     @relation("ITCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, transactionDate])
  @@index([tenantId, transactionType])
  @@index([tenantId, productId, transactionDate])
  @@unique([tenantId, idempotencyKey])
  @@map("inventory_transactions")
}

model Notification {
  id         String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId   String               @map("tenant_id") @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  type       NotificationType
  priority   NotificationPriority @default(NORMAL)
  title      String               @db.VarChar(255)
  message    String               @db.VarChar(2000)
  entityType String?              @map("entity_type") @db.VarChar(100)
  entityId   String?              @map("entity_id") @db.Uuid
  actionUrl  String?              @map("action_url") @db.VarChar(500)
  isRead     Boolean              @default(false) @map("is_read")
  readAt     DateTime?            @map("read_at")
  metadata   Json?
  createdAt  DateTime             @default(now()) @map("created_at")
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, type])
  @@map("notifications")
}

