  standardCost      Decimal   @default(0) @map("standard_cost") @db.Decimal(18, 4)
  lastReceiptCost   Decimal   @default(0) @map("last_receipt_cost") @db.Decimal(18, 4)
  lastReceiptDate   DateTime? @map("last_receipt_date")
  lastIssueCost     Decimal?  @map("last_issue_cost") @db.Decimal(18, 4)
  lastIssueDate     DateTime? @map("last_issue_date")
  currency          String    @default("USD") @db.VarChar(3)
  version           Int       @default(1)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, productId, locationId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("item_costs")
}

/// WIP cost accumulation per work order — breakdown by element
model WIPCostAccumulation {
