generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, uuid_ossp(map: "uuid-ossp")]
}

model Tenant {
  id                   String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                 String               @db.VarChar(255)
  slug                 String               @unique @db.VarChar(100)
  domain               String?              @unique @db.VarChar(255)
  subdomain            String?              @unique @db.VarChar(100)
  status               TenantStatus         @default(ACTIVE)
  licenseStatus        TenantLicenseStatus  @default(ACTIVE) @map("license_status")
  licenseExpiresAt     DateTime?            @map("license_expires_at")
  tier                 TenantTier           @default(STARTER)
  settings             Json                 @default("{}")
  logoUrl              String?              @db.VarChar(500)
  primaryColor         String?              @db.VarChar(7)
  timezone             String               @default("UTC") @db.VarChar(50)
  fiscalYearStart      Int                  @default(1)
  defaultCurrency      String               @default("USD") @db.VarChar(3)
  dataRetentionDays    Int                  @default(2555)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  accounts             Account[]
  actuals              Actual[]
  assumptions          Assumption[]
  auditLogs            AuditLog[]
  costCenters          CostCenter[]
  customers            Customer[]
  dataImports          DataImport[]
  domainMappings       DomainMapping[]
  forecasts            Forecast[]
  locations            Location[]
  mappingTemplates     MappingTemplate[]
  notifications        Notification[]
  passwordResetTokens  PasswordResetToken[]
  planVersions         PlanVersion[]
  products             Product[]
  refreshTokens        RefreshToken[]
  reports              Report[]
  scenarios            Scenario[]
  users                User[]
  unitOfMeasures       UnitOfMeasure[]      @relation("TenantUoms")
  productCategories    ProductCategory[]    @relation("TenantProductCategories")
  productBrands        ProductBrand[]       @relation("TenantProductBrands")
  productSubcategories ProductSubcategory[] @relation("TenantProductSubcategories")
  channels             Channel[]            @relation("TenantChannels")
  tenantModules        TenantModule[]
  tenantRoles          TenantRole[]

  @@map("tenants")
}

model Report {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?
  type        String   @default("line") @db.VarChar(50)
  config      Json     @default("{}")
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("reports")
}

model DomainMapping {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  domain     String    @unique @db.VarChar(255)
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  sslEnabled Boolean   @default(false) @map("ssl_enabled")
  createdAt  DateTime  @default(now()) @map("created_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("domain_mappings")
}

model User {
  id                              String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                        String                   @map("tenant_id") @db.Uuid
  email                           String                   @db.VarChar(255)
  passwordHash                    String                   @map("password_hash") @db.VarChar(255)
  firstName                       String                   @map("first_name") @db.VarChar(100)
  lastName                        String                   @map("last_name") @db.VarChar(100)
  role                            UserRole                 @default(VIEWER)
  status                          UserStatus               @default(ACTIVE)
  avatarUrl                       String?                  @map("avatar_url") @db.VarChar(500)
  lastLoginAt                     DateTime?                @map("last_login_at")
  passwordChangedAt               DateTime?                @map("password_changed_at")
  failedLoginCount                Int                      @default(0) @map("failed_login_count")
  lockedUntil                     DateTime?                @map("locked_until")
  mfaEnabled                      Boolean                  @default(false) @map("mfa_enabled")
  mfaSecret                       String?                  @map("mfa_secret") @db.VarChar(255)
  mustResetPassword                Boolean                  @default(false) @map("must_reset_password")
  createdAt                       DateTime                 @default(now()) @map("created_at")
  updatedAt                       DateTime                 @updatedAt @map("updated_at")
  auditLogs                       AuditLog[]
  forecastOverridesApproved       ForecastOverride[]       @relation("ForecastOverrideApprovedBy")
  forecastOverridesRequested      ForecastOverride[]       @relation("ForecastOverrideRequestedBy")
  forecastReconciliationsApproved ForecastReconciliation[] @relation("ForecastReconciliationApprovedBy")
  forecastRunsRequested           ForecastRun[]            @relation("ForecastRunRequestedBy")
  forecastsCreated                Forecast[]               @relation("ForecastCreatedBy")
  forecastsModified               Forecast[]               @relation("ForecastModifiedBy")
  notifications                   Notification[]
  passwordResetTokens             PasswordResetToken[]
  planVersionsApproved            PlanVersion[]            @relation("PlanVersionApprovedBy")
  planVersions                    PlanVersion[]            @relation("PlanVersionCreatedBy")
  refreshTokens                   RefreshToken[]
  tenant                          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrdersCreated           PurchaseOrder[]          @relation("POCreatedBy")
  purchaseOrdersApproved          PurchaseOrder[]          @relation("POApprovedBy")
  goodsReceiptsReceived           GoodsReceipt[]           @relation("GRReceivedBy")
  workOrdersCreated               WorkOrder[]              @relation("WOCreatedBy")
  materialIssuesIssued            MaterialIssue[]          @relation("MIIssuedBy")
  productionCompletionsCompleted  ProductionCompletion[]   @relation("PCCompletedBy")
  laborEntries                    LaborEntry[]             @relation("LaborWorker")
  inventoryTransactionsCreated    InventoryTransaction[]   @relation("ITCreatedBy")
  reservationsPlaced              InventoryReservation[]   @relation("ReservationPlacedBy")
  reservationsReleased            InventoryReservation[]   @relation("ReservationReleasedBy")
  holdsPlaced                     InventoryHold[]          @relation("HoldPlacedBy")
  holdsReleased                   InventoryHold[]          @relation("HoldReleasedBy")
  journalEntriesPosted            JournalEntry[]           @relation("JournalPostedBy")
  ncrReported                     NonConformanceReport[]   @relation("NCRReportedBy")
  ncrAssigned                     NonConformanceReport[]   @relation("NCRAssignedTo")
  ncrClosed                       NonConformanceReport[]   @relation("NCRClosedBy")
  capaAssigned                    CorrectiveAction[]       @relation("CAPAAssignedTo")
  capaVerified                    CorrectiveAction[]       @relation("CAPAVerifiedBy")
  capaCreated                     CorrectiveAction[]       @relation("CAPACreatedBy")
  ecoRequested                    EngineeringChangeOrder[] @relation("ECORequestedBy")
  ecoApproved                     EngineeringChangeOrder[] @relation("ECOApprovedBy")
  ecoImplemented                  EngineeringChangeOrder[] @relation("ECOImplementedBy")
  managedCostCenters              CostCenter[]             @relation("CostCenterManager")
  sopCyclesDemandManaged          SOPCycle[]               @relation("SOPDemandManager")
  sopCyclesSupplyManaged          SOPCycle[]               @relation("SOPSupplyManager")
  sopCyclesFinanceManaged         SOPCycle[]               @relation("SOPFinanceManager")
  sopCyclesExecutiveSponsored     SOPCycle[]               @relation("SOPExecutiveSponsor")
  customRoleId                    String?                  @map("custom_role_id") @db.Uuid
  customRole                      TenantRole?              @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Product {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String                    @map("tenant_id") @db.Uuid
  code                    String                    @db.VarChar(50)
  name                    String                    @db.VarChar(255)
  description             String?
  category                String?                   @db.VarChar(100)
  categoryId              String?                   @map("category_id") @db.Uuid
  subcategory             String?                   @db.VarChar(100)
  subcategoryId           String?                   @map("subcategory_id") @db.Uuid
  brand                   String?                   @db.VarChar(100)
  brandId                 String?                   @map("brand_id") @db.Uuid
  unitOfMeasure           String?                   @map("unit_of_measure") @db.VarChar(20)
  unitOfMeasureId         String?                   @map("unit_of_measure_id") @db.Uuid
  standardCost            Decimal?                  @map("standard_cost") @db.Decimal(18, 4)
  listPrice               Decimal?                  @map("list_price") @db.Decimal(18, 4)
  status                  DimensionStatus           @default(ACTIVE)
  qcRequired              Boolean                   @default(false) @map("qc_required")
  batchTracked            Boolean                   @default(false) @map("batch_tracked")
  attributes              Json                      @default("{}")
  externalId              String?                   @map("external_id") @db.VarChar(100)
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  actuals                 Actual[]
  assumptions             Assumption[]
  forecastOverrides       ForecastOverride[]
  forecastReconciliations ForecastReconciliation[]
  forecastResults         ForecastResult[]
  forecasts               Forecast[]
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryRef             ProductCategory?          @relation("ProductCategoryProducts", fields: [categoryId], references: [id])
  subcategoryRef          ProductSubcategory?       @relation("ProductSubcategoryProducts", fields: [subcategoryId], references: [id])
  brandRef                ProductBrand?             @relation("ProductBrandProducts", fields: [brandId], references: [id])
  unitOfMeasureRef        UnitOfMeasure?            @relation("ProductUnitOfMeasure", fields: [unitOfMeasureId], references: [id])
  accuracyMetrics         ForecastAccuracyMetric[]  @relation("ProductAccuracyMetrics")
  inspections             QualityInspection[]       @relation("ProductInspections")
  uomConversions          UnitOfMeasureConversion[] @relation("ProductUomConversions")
  sopGaps                 SOPGapAnalysis[]          @relation("ProductSOPGaps")
  contractLines           PurchaseContractLine[]    @relation("ProductContractLines")
  costings                ProductCosting[]          @relation("ProductCostings")
  billsOfMaterial         BillOfMaterial[]          @relation("ProductBOMs")
  bomComponents           BOMComponent[]            @relation("ComponentProduct")
  inventoryPolicies       InventoryPolicy[]         @relation("ProductPolicies")
  inventoryLevels         InventoryLevel[]          @relation("ProductLevels")
  workOrders              WorkOrder[]               @relation("ProductWorkOrders")
  purchaseOrderLines      PurchaseOrderLine[]       @relation("ProductPOLines")
  goodsReceiptLines       GoodsReceiptLine[]        @relation("ProductGRLines")
  materialIssues          MaterialIssue[]           @relation("ProductMaterialIssues")
  productionCompletions   ProductionCompletion[]    @relation("ProductCompletions")
  inventoryTransactions   InventoryTransaction[]    @relation("ProductTransactions")
  batches                 Batch[]                   @relation("ProductBatches")
  inventoryReservations   InventoryReservation[]    @relation("ProductReservations")
  inventoryHolds          InventoryHold[]           @relation("ProductHolds")
  inventoryLedgerEntries  InventoryLedger[]         @relation("ProductLedgerEntries")
  npiEntries              NewProductIntroduction[]  @relation("ProductNPI")
  inspectionPlans         InspectionPlan[]          @relation("ProductInspectionPlans")
  nonConformanceReports   NonConformanceReport[]    @relation("ProductNCRs")
  plannedOrders           PlannedOrder[]            @relation("ProductPlannedOrders")
  mrpRequirements         MRPRequirement[]          @relation("ProductMRPRequirements")
  promotionTargets        PromotionProductTarget[]  @relation("PromotionProductTargetProduct")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, categoryId])
  @@index([tenantId, subcategoryId])
  @@index([tenantId, brandId])
  @@index([tenantId, unitOfMeasureId])
  @@map("products")
}

model Location {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String                    @map("tenant_id") @db.Uuid
  code                    String                    @db.VarChar(50)
  name                    String                    @db.VarChar(255)
  type                    LocationType              @default(WAREHOUSE)
  address                 String?                   @db.VarChar(500)
  city                    String?                   @db.VarChar(100)
  state                   String?                   @db.VarChar(100)
  country                 String?                   @db.VarChar(100)
  postalCode              String?                   @map("postal_code") @db.VarChar(20)
  region                  String?                   @db.VarChar(100)
  timezone                String?                   @db.VarChar(50)
  status                  DimensionStatus           @default(ACTIVE)
  attributes              Json                      @default("{}")
  externalId              String?                   @map("external_id") @db.VarChar(100)
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  actuals                 Actual[]
  assumptions             Assumption[]
  forecastOverrides       ForecastOverride[]
  forecastReconciliations ForecastReconciliation[]
  forecastResults         ForecastResult[]
  forecasts               Forecast[]
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accuracyMetrics         ForecastAccuracyMetric[]  @relation("LocationAccuracyMetrics")
  hierarchyNodes          LocationHierarchy[]       @relation("LocationHierarchyNode")
  costings                ProductCosting[]          @relation("LocationCostings")
  workCenters             WorkCenter[]              @relation("LocationWorkCenters")
  inventoryPolicies       InventoryPolicy[]         @relation("LocationPolicies")
  inventoryLevels         InventoryLevel[]          @relation("LocationLevels")
  workOrders              WorkOrder[]               @relation("LocationWorkOrders")
  purchaseOrders          PurchaseOrder[]           @relation("LocationPurchaseOrders")
  goodsReceipts           GoodsReceipt[]            @relation("LocationGoodsReceipts")
  materialIssues          MaterialIssue[]           @relation("LocationMaterialIssues")
  productionCompletions   ProductionCompletion[]    @relation("LocationCompletions")
  inventoryTransactions   InventoryTransaction[]    @relation("LocationTransactions")
  inventoryTransfersTo    InventoryTransaction[]    @relation("TransferToLocation")
  batches                 Batch[]                   @relation("LocationBatches")
  inventoryReservations   InventoryReservation[]    @relation("LocationReservations")
  inventoryHolds          InventoryHold[]           @relation("LocationHolds")
  inventoryLedgerEntries  InventoryLedger[]         @relation("LocationLedgerEntries")
  plannedOrders           PlannedOrder[]            @relation("LocationPlannedOrders")
  plannedOrderSources     PlannedOrder[]            @relation("SourceLocationPlannedOrders")
  postingProfiles         PostingProfile[]          @relation("PostingProfileLocation")
  nonConformanceReports   NonConformanceReport[]    @relation("LocationNCRs")
  qualityInspections      QualityInspection[]       @relation("LocationInspections")
  promotionTargets        PromotionLocationTarget[] @relation("PromotionLocationTargetLocation")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, region])
  @@map("locations")
}

model Customer {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String                    @map("tenant_id") @db.Uuid
  code                    String                    @db.VarChar(50)
  name                    String                    @db.VarChar(255)
  type                    CustomerType              @default(DIRECT)
  segment                 String?                   @db.VarChar(100)
  industry                String?                   @db.VarChar(100)
  country                 String?                   @db.VarChar(100)
  region                  String?                   @db.VarChar(100)
  creditLimit             Decimal?                  @map("credit_limit") @db.Decimal(18, 2)
  paymentTerms            String?                   @map("payment_terms") @db.VarChar(50)
  status                  DimensionStatus           @default(ACTIVE)
  attributes              Json                      @default("{}")
  externalId              String?                   @map("external_id") @db.VarChar(100)
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  actuals                 Actual[]
  assumptions             Assumption[]
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  forecastOverrides       ForecastOverride[]
  forecastReconciliations ForecastReconciliation[]
  forecastResults         ForecastResult[]
  forecasts               Forecast[]
  promotionTargets        PromotionCustomerTarget[] @relation("PromotionCustomerTargetCustomer")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, segment])
  @@map("customers")
}

model Account {
  id                      String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String                   @map("tenant_id") @db.Uuid
  code                    String                   @db.VarChar(50)
  name                    String                   @db.VarChar(255)
  type                    AccountType
  category                String?                  @db.VarChar(100)
  parentId                String?                  @map("parent_id") @db.Uuid
  level                   Int                      @default(1)
  isRollup                Boolean                  @default(false) @map("is_rollup")
  sign                    Int                      @default(1)
  status                  DimensionStatus          @default(ACTIVE)
  externalId              String?                  @map("external_id") @db.VarChar(100)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  parent                  Account?                 @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                Account[]                @relation("AccountHierarchy")
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actuals                 Actual[]
  assumptions             Assumption[]
  forecastOverrides       ForecastOverride[]
  forecastReconciliations ForecastReconciliation[]
  forecastResults         ForecastResult[]
  forecasts               Forecast[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([parentId])
  @@map("accounts")
}

model CostCenter {
  id                      String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String                   @map("tenant_id") @db.Uuid
  code                    String                   @db.VarChar(50)
  name                    String                   @db.VarChar(255)
  department              String?                  @db.VarChar(100)
  manager                 String?                  @db.VarChar(255)
  managerId               String?                  @map("manager_id") @db.Uuid
  parentId                String?                  @map("parent_id") @db.Uuid
  status                  DimensionStatus          @default(ACTIVE)
  externalId              String?                  @map("external_id") @db.VarChar(100)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  actuals                 Actual[]
  parent                  CostCenter?              @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children                CostCenter[]             @relation("CostCenterHierarchy")
  managerUser             User?                    @relation("CostCenterManager", fields: [managerId], references: [id])
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  forecastOverrides       ForecastOverride[]
  forecastReconciliations ForecastReconciliation[]
  forecastResults         ForecastResult[]
  forecasts               Forecast[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, managerId])
  @@map("cost_centers")
}

model Actual {
  id              String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  actualType      ActualType               @map("actual_type")
  periodDate      DateTime                 @map("period_date") @db.Date
  periodType      PeriodType               @default(MONTHLY) @map("period_type")
  productId       String?                  @map("product_id") @db.Uuid
  locationId      String?                  @map("location_id") @db.Uuid
  customerId      String?                  @map("customer_id") @db.Uuid
  accountId       String?                  @map("account_id") @db.Uuid
  costCenterId    String?                  @map("cost_center_id") @db.Uuid
  quantity        Decimal?                 @db.Decimal(18, 4)
  amount          Decimal                  @db.Decimal(18, 4)
  currency        String                   @default("USD") @db.VarChar(3)
  amountLocal     Decimal?                 @map("amount_local") @db.Decimal(18, 4)
  currencyLocal   String?                  @map("currency_local") @db.VarChar(3)
  exchangeRate    Decimal?                 @map("exchange_rate") @db.Decimal(18, 8)
  sourceSystem    String?                  @map("source_system") @db.VarChar(100)
  sourceReference String?                  @map("source_reference") @db.VarChar(255)
  importId        String?                  @map("import_id") @db.Uuid
  attributes      Json                     @default("{}")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  account         Account?                 @relation(fields: [accountId], references: [id])
  costCenter      CostCenter?              @relation(fields: [costCenterId], references: [id])
  customer        Customer?                @relation(fields: [customerId], references: [id])
  dataImport      DataImport?              @relation(fields: [importId], references: [id])
  location        Location?                @relation(fields: [locationId], references: [id])
  product         Product?                 @relation(fields: [productId], references: [id])
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reconciliations ForecastReconciliation[]

  @@index([tenantId, periodDate])
  @@index([tenantId, actualType, periodDate])
  @@index([tenantId, productId, periodDate])
  @@index([tenantId, locationId, periodDate])
  @@index([tenantId, customerId, periodDate])
  @@index([tenantId, accountId, periodDate])
  @@index([importId])
  @@unique([tenantId, sourceSystem, sourceReference])
  @@map("actuals")
}

model PlanVersion {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  name            String        @db.VarChar(255)
  description     String?
  planType        PlanType      @map("plan_type")
  status          PlanStatus    @default(DRAFT)
  version         Int           @default(1)
  startDate       DateTime      @map("start_date") @db.Date
  endDate         DateTime      @map("end_date") @db.Date
  periodType      PeriodType    @default(MONTHLY) @map("period_type")
  isLocked        Boolean       @default(false) @map("is_locked")
  lockedAt        DateTime?     @map("locked_at")
  lockedReason    String?       @map("locked_reason") @db.VarChar(500)
  approvedAt      DateTime?     @map("approved_at")
  approvedById    String?       @map("approved_by_id") @db.Uuid
  parentVersionId String?       @map("parent_version_id") @db.Uuid
  createdById     String        @map("created_by_id") @db.Uuid
  settings        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  assumptions     Assumption[]
  forecastRuns    ForecastRun[]
  forecasts       Forecast[]
  approvedBy      User?         @relation("PlanVersionApprovedBy", fields: [approvedById], references: [id])
  createdBy       User          @relation("PlanVersionCreatedBy", fields: [createdById], references: [id])
  parentVersion   PlanVersion?  @relation("PlanVersionLineage", fields: [parentVersionId], references: [id])
  childVersions   PlanVersion[] @relation("PlanVersionLineage")
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scenarios       Scenario[]

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, planType])
  @@map("plan_versions")
}

model Scenario {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  planVersionId String        @map("plan_version_id") @db.Uuid
  name          String        @db.VarChar(255)
  description   String?
  scenarioType  ScenarioType  @default(BASE) @map("scenario_type")
  status        PlanStatus    @default(DRAFT)
