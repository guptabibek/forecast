/// Marg EDE integration configuration per tenant
model MargSyncConfig {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  companyCode     String          @map("company_code") @db.VarChar(100)
  margKey         String          @map("marg_key") @db.VarChar(255)
  decryptionKey   String          @map("decryption_key") @db.VarChar(255)
  apiBaseUrl      String          @default("https://corporate.margerp.com") @map("api_base_url") @db.VarChar(500)
  companyId       Int             @default(0) @map("company_id")
  isActive        Boolean         @default(true) @map("is_active")
  syncFrequency   String          @default("DAILY") @map("sync_frequency") @db.VarChar(20)
  lastSyncAt      DateTime?       @map("last_sync_at")
  lastSyncStatus  MargSyncStatus  @default(IDLE) @map("last_sync_status")
  lastSyncIndex   Int             @default(0) @map("last_sync_index")
  lastSyncDatetime String?        @map("last_sync_datetime") @db.VarChar(50)
  lastAccountingSyncAt DateTime?  @map("last_accounting_sync_at")
  lastAccountingSyncStatus MargSyncStatus @default(IDLE) @map("last_accounting_sync_status")
  lastAccountingSyncIndex Int     @default(0) @map("last_accounting_sync_index")
  lastAccountingSyncDatetime String? @map("last_accounting_sync_datetime") @db.VarChar(50)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  syncLogs        MargSyncLog[]

  @@unique([tenantId, companyCode])
  @@index([tenantId])
  @@map("marg_sync_configs")
}

/// Log entry for each Marg EDE sync run
model MargSyncLog {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  configId         String          @map("config_id") @db.Uuid
  status           MargSyncStatus  @default(RUNNING)
  startedAt        DateTime        @default(now()) @map("started_at")
  completedAt      DateTime?       @map("completed_at")
  productsSynced   Int             @default(0) @map("products_synced")
  partiesSynced    Int             @default(0) @map("parties_synced")
  transactionsSynced Int           @default(0) @map("transactions_synced")
  stockSynced      Int             @default(0) @map("stock_synced")
  branchesSynced   Int             @default(0) @map("branches_synced")
  vouchersSynced   Int             @default(0) @map("vouchers_synced")
  saleTypesSynced  Int             @default(0) @map("sale_types_synced")
  accountGroupsSynced Int          @default(0) @map("account_groups_synced")
  accountPostingsSynced Int        @default(0) @map("account_postings_synced")
  accountGroupBalancesSynced Int   @default(0) @map("account_group_balances_synced")
  partyBalancesSynced Int          @default(0) @map("party_balances_synced")
  outstandingsSynced Int           @default(0) @map("outstandings_synced")
  journalEntriesSynced Int         @default(0) @map("journal_entries_synced")
  errors           Json            @default("[]")
  syncIndex        Int?            @map("sync_index")
  syncDatetime     String?         @map("sync_datetime") @db.VarChar(50)
  createdAt        DateTime        @default(now()) @map("created_at")
  config           MargSyncConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([tenantId, startedAt])
  @@index([configId])
  @@map("marg_sync_logs")
}

