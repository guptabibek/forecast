  totalValue     Decimal       @map("total_value") @db.Decimal(18, 4)
  costingMethod  CostingMethod @map("costing_method")
  openLayerCount Int           @default(0) @map("open_layer_count")
  currency       String        @default("USD") @db.VarChar(3)
