  workOrder             WorkOrder?              @relation("WorkOrderInspections", fields: [workOrderId], references: [id])
  purchaseOrder         PurchaseOrder?          @relation("PurchaseOrderInspections", fields: [purchaseOrderId], references: [id])
  product               Product                 @relation("ProductInspections", fields: [productId], references: [id])
