/// Costing variance records — persisted for reporting
model CostVariance {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  varianceType    String   @map("variance_type") @db.VarChar(50)
  referenceType   String   @map("reference_type") @db.VarChar(50)
  referenceId     String   @map("reference_id") @db.Uuid
  referenceNumber String?  @map("reference_number") @db.VarChar(50)
  productId       String?  @map("product_id") @db.Uuid
  locationId      String?  @map("location_id") @db.Uuid
  fiscalPeriodId  String?  @map("fiscal_period_id") @db.Uuid
  standardAmount  Decimal  @default(0) @map("standard_amount") @db.Decimal(18, 4)
  actualAmount    Decimal  @default(0) @map("actual_amount") @db.Decimal(18, 4)
  varianceAmount  Decimal  @default(0) @map("variance_amount") @db.Decimal(18, 4)
