}

/// Landed cost allocation — distributes extra purchase costs across receipt lines
model LandedCostAllocation {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  goodsReceiptId     String   @map("goods_receipt_id") @db.Uuid
  goodsReceiptLineId String?  @map("goods_receipt_line_id") @db.Uuid
  costLayerId        String?  @map("cost_layer_id") @db.Uuid
  costCategory       String   @map("cost_category") @db.VarChar(50)
  allocationMethod   String   @default("BY_VALUE") @map("allocation_method") @db.VarChar(30)
  allocatedAmount    Decimal  @map("allocated_amount") @db.Decimal(18, 4)
  currency           String   @default("USD") @db.VarChar(3)
  vendorInvoiceRef   String?  @map("vendor_invoice_ref") @db.VarChar(100)
  journalEntryId     String?  @map("journal_entry_id") @db.Uuid
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([tenantId, goodsReceiptId])
  @@index([costLayerId])
  @@map("landed_cost_allocations")
}

/// Fiscal period close tracking
model PeriodCloseCheckpoint {
  id                      String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId                String            @map("tenant_id") @db.Uuid
  fiscalPeriodId          String            @map("fiscal_period_id") @db.Uuid
  status                  PeriodCloseStatus @default(OPEN)
  inventoryValuationTotal Decimal           @default(0) @map("inventory_valuation_total") @db.Decimal(18, 4)
  glInventoryTotal        Decimal           @default(0) @map("gl_inventory_total") @db.Decimal(18, 4)
  discrepancy             Decimal           @default(0) @db.Decimal(18, 4)
  varianceSummary         Json?             @map("variance_summary")
  closedById              String?           @map("closed_by_id") @db.Uuid
  closedAt                DateTime?         @map("closed_at")
  reopenedById            String?           @map("reopened_by_id") @db.Uuid
  reopenedAt              DateTime?         @map("reopened_at")
  reopenReason            String?           @map("reopen_reason")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  @@unique([tenantId, fiscalPeriodId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("period_close_checkpoints")
}

// ============================================================================
// Production Branch Module — Lines, Downtime, Scrap Reasons
// ============================================================================

/// Physical production line — an ordered sequence of work centers
model ProductionLine {
  id              String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String                  @map("tenant_id") @db.Uuid
  code            String                  @db.VarChar(50)
  name            String                  @db.VarChar(255)
  description     String?
  locationId      String?                 @map("location_id") @db.Uuid
  status          DimensionStatus         @default(ACTIVE)
  outputRate      Decimal?                @map("output_rate") @db.Decimal(18, 4)
  outputUom       String?                 @map("output_uom") @db.VarChar(10)
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  stations        ProductionLineStation[]
  downtimeRecords DowntimeRecord[]        @relation("LineDowntime")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("production_lines")
}

/// Junction — assigns work centers to a production line with sequence
model ProductionLineStation {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productionLineId String         @map("production_line_id") @db.Uuid
  workCenterId     String         @map("work_center_id") @db.Uuid
  sequence         Int            @default(10)
  stationName      String?        @map("station_name") @db.VarChar(255)
  isBottleneck     Boolean        @default(false) @map("is_bottleneck")
  createdAt        DateTime       @default(now()) @map("created_at")
  productionLine   ProductionLine @relation(fields: [productionLineId], references: [id], onDelete: Cascade)

  @@unique([productionLineId, sequence])
  @@index([productionLineId])
  @@map("production_line_stations")
}

/// Master list of downtime reason codes
model DowntimeReason {
  id        String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  code      String           @db.VarChar(50)
  name      String           @db.VarChar(255)
  category  String           @default("UNPLANNED") @db.VarChar(50)
  isPlanned Boolean          @default(false) @map("is_planned")
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  records   DowntimeRecord[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("downtime_reasons")
}

/// Downtime event record
model DowntimeRecord {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  downtimeReasonId String          @map("downtime_reason_id") @db.Uuid
  productionLineId String?         @map("production_line_id") @db.Uuid
  workOrderId      String?         @map("work_order_id") @db.Uuid
  startTime        DateTime        @map("start_time")
  endTime          DateTime?       @map("end_time")
  durationMinutes  Decimal?        @map("duration_minutes") @db.Decimal(10, 2)
  notes            String?
  reportedById     String?         @map("reported_by_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  reason           DowntimeReason  @relation(fields: [downtimeReasonId], references: [id])
  productionLine   ProductionLine? @relation("LineDowntime", fields: [productionLineId], references: [id])

  @@index([tenantId, productionLineId])
  @@index([tenantId, startTime])
  @@map("downtime_records")
}

/// Tracks which modules/features are enabled per tenant.
/// Super-admin configures these to control what each tenant can access.
model TenantModule {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  module    String   @db.VarChar(50)
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
  @@map("tenant_modules")
}

/// Dynamic RBAC: tenant-scoped roles with module access + action permissions.
model TenantRole {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(100)
  slug         String   @db.VarChar(100)
  description  String?  @db.VarChar(500)
  /// JSON map of module keys to boolean (e.g. {planning: true, manufacturing: false})
  moduleAccess Json     @default("{}") @map("module_access")
  /// JSON array of permission strings (e.g. ["plan:create","plan:edit","forecast:read"])
  permissions  Json     @default("[]") @map("permissions")
  isSystem     Boolean  @default(false) @map("is_system")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("tenant_roles")
}

/// Master list of scrap reason codes
model ScrapReason {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  code      String   @db.VarChar(50)
  name      String   @db.VarChar(255)
  category  String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("scrap_reasons")
}
