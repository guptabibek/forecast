# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forecast_saas?schema=public

# Redis (optional — omit to disable background queues)
# Marg sync falls back to inline execution without Redis; forecast runs/imports still require it.
# REDIS_URL=redis://localhost:6379

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32
JWT_EXPIRES_IN=15m

# API Configuration
API_PORT=3000
NODE_ENV=development

# Global API rate limits per client IP.
# Auth endpoints have stricter route-level limits in code.
THROTTLE_SHORT_LIMIT=100
THROTTLE_MEDIUM_LIMIT=500
THROTTLE_LONG_LIMIT=3000
TRUST_PROXY_HOPS=1

# SaaS domain (subdomains are auto-resolved, e.g. demo.localhost)
MAIN_DOMAIN=localhost

# AI NLQ reporting is fully per-tenant:
#   - Superadmin gates the module per tenant via the tenant_modules table
#     (module key: 'ai-reporting').
#   - Tenant admins manage provider, model, API key, timeouts, limits, rate
#     caps, masking, and summary toggle from Settings → AI Reporting.
# Optional: 32+ char key for encrypting tenant API keys at rest.
# Falls back to JWT_SECRET if unset.
AI_CONFIG_ENCRYPTION_KEY=
# Optional override when the API process runs from a non-repo working directory
# AI_SEMANTIC_CATALOG_PATH=apps/api/ai-reporting/semantic-catalog.json

# Optional: Sentry for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
