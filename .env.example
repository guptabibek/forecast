# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forecast_saas?schema=public

# Redis (optional — omit to disable background queues)
# Marg sync falls back to inline execution without Redis; forecast runs/imports still require it.
# REDIS_URL=redis://localhost:6379

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32
JWT_EXPIRES_IN=15m

# API Configuration
API_PORT=3000
NODE_ENV=development

# SaaS domain (subdomains are auto-resolved, e.g. demo.localhost)
MAIN_DOMAIN=localhost

# OpenAI (for AI Hybrid forecasting model)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Sentry for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
