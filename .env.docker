# Docker runtime configuration for local/UAT compose deployment
NODE_ENV=development

# Web/API ports exposed on host
WEB_PORT=3080
API_EXTERNAL_PORT=3101
POSTGRES_PORT=5432
REDIS_EXTERNAL_PORT=6379

# Postgres
POSTGRES_DB=forecast_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App security secrets (set strong values before shared UAT)
JWT_SECRET=uat-super-secret-jwt-key-32-characters-minimum
JWT_REFRESH_SECRET=uat-super-secret-refresh-key-32-chars-min
ENCRYPTION_KEY=12345678901234567890123456789012
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_DAYS=7
ALLOW_DEMO_TENANT_FALLBACK=false

# Web/API cross-origin and base URLs
FRONTEND_URL=http://demo.localhost:3080
CORS_ORIGINS=http://localhost:3080,http://demo.localhost:3080,http://127.0.0.1:3080
MAIN_DOMAIN=localhost
VITE_API_URL=/api/v1

# Optional integrations
OPENAI_API_KEY=
