# Production Environment Configuration
# Copy this file to .env and update values

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/forecast_saas?schema=public

# Redis (optional — omit to disable background queues; set to enable forecast runs / imports)
# Marg sync falls back to inline execution without Redis.
# REDIS_URL=redis://redis:6379

# JWT Secrets (MUST CHANGE IN PRODUCTION - use 32+ character random strings)
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_1
JWT_REFRESH_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_2
JWT_EXPIRES_IN=15m

# API Configuration
API_PORT=3000
NODE_ENV=production

# Global API rate limits per client IP.
# Auth endpoints have stricter route-level limits in code.
THROTTLE_SHORT_LIMIT=100
THROTTLE_MEDIUM_LIMIT=500
THROTTLE_LONG_LIMIT=3000
TRUST_PROXY_HOPS=1

# SaaS domain (tenant subdomains are auto-resolved, e.g. acme.your-domain.com)
MAIN_DOMAIN=your-domain.com

# AI NLQ reporting is fully per-tenant:
#   - Superadmin gates the module per tenant via the tenant_modules table
#     (module key: 'ai-reporting').
#   - Tenant admins manage provider, model, API key, timeouts, limits, rate
#     caps, masking, and summary toggle from Settings → AI Reporting.
# 32+ char key for encrypting tenant API keys at rest. Falls back to
# JWT_SECRET if unset.
AI_CONFIG_ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_3
# Optional override when the API process runs from a non-repo working directory
# AI_SEMANTIC_CATALOG_PATH=apps/api/ai-reporting/semantic-catalog.json

# Sentry for error tracking (recommended)
# SENTRY_DSN=https://xxx@sentry.io/xxx
