# Production Environment Configuration
# Copy this file to .env and update values

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/forecast_saas?schema=public

# Redis (optional — omit to disable background queues; set to enable forecast runs / imports)
# Marg sync falls back to inline execution without Redis.
# REDIS_URL=redis://redis:6379

# JWT Secrets (MUST CHANGE IN PRODUCTION - use 32+ character random strings)
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_1
JWT_REFRESH_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_2
JWT_EXPIRES_IN=15m

# API Configuration
API_PORT=3000
NODE_ENV=production

# Frontend URL
FRONTEND_URL=https://your-domain.com

# OpenAI (for AI Hybrid forecasting model)
OPENAI_API_KEY=sk-your-production-openai-api-key

# Sentry for error tracking (recommended)
# SENTRY_DSN=https://xxx@sentry.io/xxx
