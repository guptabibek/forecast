{
  "name": "forecast-saas-orchestration",
  "private": true,
  "version": "1.0.0",
  "description": "Root orchestration scripts for Docker-based UAT deployment",
  "scripts": {
    "prod:up": "docker compose --env-file .env.docker up -d --build",
    "prod:down": "docker compose --env-file .env.docker down",
    "prod:logs": "docker compose --env-file .env.docker logs -f --tail=200",
    "prod:ps": "docker compose --env-file .env.docker ps",
    "prod:seed": "docker compose --env-file .env.docker exec api npm run db:seed",
    "prod:restart": "docker compose --env-file .env.docker up -d --build",
    "prod:rebuild": "docker compose --env-file .env.docker build --no-cache",
    "prod:reset": "docker compose --env-file .env.docker down -v"
  }
}
